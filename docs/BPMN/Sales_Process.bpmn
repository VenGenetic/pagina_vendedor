<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_Sales"
                  targetNamespace="http://menards.com/bpmn/sales"
                  exporter="Camunda Modeler" exporterVersion="5.16.0">
  <bpmn:collaboration id="Collaboration_Sales">
    <bpmn:participant id="Participant_Sales" name="Sales Process (Reservation + Return)" processRef="Process_Sales" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Sales" name="POS Sales Transaction" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Sales">
      <bpmn:lane id="Lane_Frontend" name="Frontend (POS)">
        <bpmn:flowNodeRef>StartEvent_Sale</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SelectProducts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SelectReturnItems</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Success</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SaleFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ReturnComplete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Backend" name="Backend (External Workers)">
        <bpmn:flowNodeRef>Activity_ReserveStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_StockError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_SaleExecution</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_SaleFail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ReleaseReservation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ValidateReturn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CreateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RestoreStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_UpdateSaleStatus</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- ============================== -->
    <!-- SALE FLOW (RESERVATION PATTERN) -->
    <!-- ============================== -->
    <bpmn:startEvent id="StartEvent_Sale" name="Sale Initiated">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Activity_SelectProducts" name="Select Products and Customer">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Activity_ReserveStock" name="Validate &#38; Reserve Stock"
                      camunda:asyncBefore="true"
                      camunda:type="external" camunda:topic="inventory-reserve-stock">
      <bpmn:documentation>RESERVATION PATTERN: Moves items into RESERVED status immediately upon validation. Prevents race conditions during checkout.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:failedJobRetryTimeCycle>R3/PT1M</camunda:failedJobRetryTimeCycle>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_StockValid" name="Stock Reserved?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="Event_StockError" name="Stock Insufficient">
      <bpmn:incoming>Flow_No</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_Stock" errorRef="Error_StockInsufficient" />
    </bpmn:endEvent>

    <!-- Subprocess with Compensation for post-reservation tasks -->
    <bpmn:subProcess id="SubProcess_SaleExecution" name="Sale Execution (Compensatable)">
      <bpmn:incoming>Flow_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_SubComplete</bpmn:outgoing>

      <bpmn:startEvent id="SubStart">
        <bpmn:outgoing>SubFlow_1</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:serviceTask id="Activity_UpsertCustomer" name="Upsert Customer Data"
                        camunda:asyncBefore="true"
                        camunda:type="external" camunda:topic="customer-upsert">
        <bpmn:incoming>SubFlow_1</bpmn:incoming>
        <bpmn:outgoing>SubFlow_2</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:serviceTask id="Activity_CreateSaleRecord" name="Insert Sale Header"
                        camunda:type="external" camunda:topic="sales-create-record">
        <bpmn:incoming>SubFlow_2</bpmn:incoming>
        <bpmn:outgoing>SubFlow_3</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:serviceTask id="Activity_CommitInventory" name="Commit Reservation (OUT)"
                        camunda:asyncBefore="true"
                        camunda:type="external" camunda:topic="inventory-commit-reservation">
        <bpmn:documentation>Converts RESERVED status to actual OUT movement. Links to reservation_id.</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:failedJobRetryTimeCycle>R3/PT30S</camunda:failedJobRetryTimeCycle>
        </bpmn:extensionElements>
        <bpmn:incoming>SubFlow_3</bpmn:incoming>
        <bpmn:outgoing>SubFlow_4</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:serviceTask id="Activity_CreateFinancials" name="Insert Income &#38; Shipping Transactions"
                        camunda:type="external" camunda:topic="finance-income-transaction">
        <bpmn:incoming>SubFlow_4</bpmn:incoming>
        <bpmn:outgoing>SubFlow_5</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:endEvent id="SubEnd">
        <bpmn:incoming>SubFlow_5</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="SubFlow_1" sourceRef="SubStart" targetRef="Activity_UpsertCustomer" />
      <bpmn:sequenceFlow id="SubFlow_2" sourceRef="Activity_UpsertCustomer" targetRef="Activity_CreateSaleRecord" />
      <bpmn:sequenceFlow id="SubFlow_3" sourceRef="Activity_CreateSaleRecord" targetRef="Activity_CommitInventory" />
      <bpmn:sequenceFlow id="SubFlow_4" sourceRef="Activity_CommitInventory" targetRef="Activity_CreateFinancials" />
      <bpmn:sequenceFlow id="SubFlow_5" sourceRef="Activity_CreateFinancials" targetRef="SubEnd" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_SaleFail" name="Sale Execution Failed" attachedToRef="SubProcess_SaleExecution">
      <bpmn:outgoing>Flow_Compensate</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_SaleFail" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Activity_ReleaseReservation" name="Release Stock Reservation"
                      camunda:type="external" camunda:topic="inventory-release-reservation">
      <bpmn:documentation>COMPENSATION: If any step in the sale execution fails, release the reserved stock back to available inventory.</bpmn:documentation>
      <bpmn:incoming>Flow_Compensate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToFailed</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_SaleFailed" name="Sale Failed (Stock Released)">
      <bpmn:incoming>Flow_ToFailed</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Success" name="Sale Completed">
      <bpmn:incoming>Flow_SubComplete</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ============================== -->
    <!-- RETURN/REFUND FLOW -->
    <!-- ============================== -->
    <bpmn:startEvent id="StartEvent_Return" name="Return Requested">
      <bpmn:outgoing>Flow_Ret1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Activity_SelectReturnItems" name="Select Sale &#38; Items to Return">
      <bpmn:incoming>Flow_Ret1</bpmn:incoming>
      <bpmn:outgoing>Flow_Ret2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Activity_ValidateReturn" name="Validate Original Sale &#38; Items"
                      camunda:asyncBefore="true"
                      camunda:type="external" camunda:topic="sales-validate-return">
      <bpmn:documentation>Verifies the sale exists, items are eligible for return, and return is within policy window.</bpmn:documentation>
      <bpmn:incoming>Flow_Ret2</bpmn:incoming>
      <bpmn:outgoing>Flow_Ret3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_CreateRefund" name="Create REVERSAL Transaction"
                      camunda:asyncBefore="true"
                      camunda:type="external" camunda:topic="finance-create-refund">
      <bpmn:documentation>COMPENSATING TRANSACTION: Creates a REFUND/REVERSAL transaction that inverts the original INCOME. Maintains zero-sum ledger integrity.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:failedJobRetryTimeCycle>R3/PT1M</camunda:failedJobRetryTimeCycle>
        <camunda:inputOutput>
          <camunda:inputParameter name="transactionType">REFUND</camunda:inputParameter>
          <camunda:inputParameter name="linkToOriginal">${originalTransactionGroupId}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Ret3</bpmn:incoming>
      <bpmn:outgoing>Flow_Ret4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_RestoreStock" name="Restore Stock (IN Movement)"
                      camunda:type="external" camunda:topic="inventory-restore-stock">
      <bpmn:documentation>Creates an IN movement to restore stock. Links to the return transaction for audit trail.</bpmn:documentation>
      <bpmn:incoming>Flow_Ret4</bpmn:incoming>
      <bpmn:outgoing>Flow_Ret5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_UpdateSaleStatus" name="Update Sale Status to RETURNED"
                      camunda:type="external" camunda:topic="sales-update-status-returned">
      <bpmn:documentation>Marks the original sale_header as RETURNED so POS reflects the completed return.</bpmn:documentation>
      <bpmn:incoming>Flow_Ret5</bpmn:incoming>
      <bpmn:outgoing>Flow_Ret6</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_ReturnComplete" name="Return Processed">
      <bpmn:incoming>Flow_Ret6</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows - Sale -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_Sale" targetRef="Activity_SelectProducts" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_SelectProducts" targetRef="Activity_ReserveStock" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Activity_ReserveStock" targetRef="Gateway_StockValid" />
    <bpmn:sequenceFlow id="Flow_Yes" name="Yes" sourceRef="Gateway_StockValid" targetRef="SubProcess_SaleExecution">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${reservationSuccess == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_No" name="No" sourceRef="Gateway_StockValid" targetRef="Event_StockError">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${reservationSuccess == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SubComplete" sourceRef="SubProcess_SaleExecution" targetRef="EndEvent_Success" />
    <bpmn:sequenceFlow id="Flow_Compensate" sourceRef="BoundaryEvent_SaleFail" targetRef="Activity_ReleaseReservation" />
    <bpmn:sequenceFlow id="Flow_ToFailed" sourceRef="Activity_ReleaseReservation" targetRef="EndEvent_SaleFailed" />

    <!-- Sequence Flows - Return -->
    <bpmn:sequenceFlow id="Flow_Ret1" sourceRef="StartEvent_Return" targetRef="Activity_SelectReturnItems" />
    <bpmn:sequenceFlow id="Flow_Ret2" sourceRef="Activity_SelectReturnItems" targetRef="Activity_ValidateReturn" />
    <bpmn:sequenceFlow id="Flow_Ret3" sourceRef="Activity_ValidateReturn" targetRef="Activity_CreateRefund" />
    <bpmn:sequenceFlow id="Flow_Ret4" sourceRef="Activity_CreateRefund" targetRef="Activity_RestoreStock" />
    <bpmn:sequenceFlow id="Flow_Ret5" sourceRef="Activity_RestoreStock" targetRef="Activity_UpdateSaleStatus" />
    <bpmn:sequenceFlow id="Flow_Ret6" sourceRef="Activity_UpdateSaleStatus" targetRef="EndEvent_ReturnComplete" />

  </bpmn:process>

  <bpmn:error id="Error_StockInsufficient" name="Stock Insufficient" errorCode="ERR_STOCK_001" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_Sales">
    <bpmndi:BPMNPlane id="BPMNPlane_Sales" bpmnElement="Collaboration_Sales">
      <bpmndi:BPMNShape id="Participant_Sales_di" bpmnElement="Participant_Sales" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="620" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Frontend_di" bpmnElement="Lane_Frontend" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1470" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Backend_di" bpmnElement="Lane_Backend" isHorizontal="true">
        <dc:Bounds x="190" y="280" width="1470" height="420" />
      </bpmndi:BPMNShape>
      <!-- Sale Flow Shapes -->
      <bpmndi:BPMNShape id="StartEvent_Sale_di" bpmnElement="StartEvent_Sale">
        <dc:Bounds x="212" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="198" y="175" width="64" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SelectProducts_di" bpmnElement="Activity_SelectProducts">
        <dc:Bounds x="300" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ReserveStock_di" bpmnElement="Activity_ReserveStock">
        <dc:Bounds x="460" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_StockValid_di" bpmnElement="Gateway_StockValid" isMarkerVisible="true">
        <dc:Bounds x="615" y="335" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="598" y="311" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_StockError_di" bpmnElement="Event_StockError">
        <dc:Bounds x="622" y="442" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="599" y="485" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_SaleExecution_di" bpmnElement="SubProcess_SaleExecution" isExpanded="true">
        <dc:Bounds x="720" y="300" width="520" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubStart_di" bpmnElement="SubStart">
        <dc:Bounds x="740" y="352" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_UpsertCustomer_di" bpmnElement="Activity_UpsertCustomer">
        <dc:Bounds x="800" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_CreateSaleRecord_di" bpmnElement="Activity_CreateSaleRecord">
        <dc:Bounds x="920" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_CommitInventory_di" bpmnElement="Activity_CommitInventory">
        <dc:Bounds x="1040" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_CreateFinancials_di" bpmnElement="Activity_CreateFinancials">
        <dc:Bounds x="1160" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubEnd_di" bpmnElement="SubEnd">
        <dc:Bounds x="1282" y="352" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_SaleFail_di" bpmnElement="BoundaryEvent_SaleFail">
        <dc:Bounds x="982" y="422" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1018" y="445" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ReleaseReservation_di" bpmnElement="Activity_ReleaseReservation">
        <dc:Bounds x="1060" y="480" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SaleFailed_di" bpmnElement="EndEvent_SaleFailed">
        <dc:Bounds x="1212" y="502" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1187" y="545" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Success_di" bpmnElement="EndEvent_Success">
        <dc:Bounds x="1552" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1531" y="175" width="79" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- Return Flow Shapes -->
      <bpmndi:BPMNShape id="StartEvent_Return_di" bpmnElement="StartEvent_Return">
        <dc:Bounds x="212" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="186" y="255" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SelectReturnItems_di" bpmnElement="Activity_SelectReturnItems">
        <dc:Bounds x="300" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ValidateReturn_di" bpmnElement="Activity_ValidateReturn">
        <dc:Bounds x="460" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_CreateRefund_di" bpmnElement="Activity_CreateRefund">
        <dc:Bounds x="620" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_RestoreStock_di" bpmnElement="Activity_RestoreStock">
        <dc:Bounds x="780" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_UpdateSaleStatus_di" bpmnElement="Activity_UpdateSaleStatus">
        <dc:Bounds x="940" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ReturnComplete_di" bpmnElement="EndEvent_ReturnComplete">
        <dc:Bounds x="1552" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1528" y="255" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- Sale Flow Edges -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="248" y="150" />
        <di:waypoint x="300" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="150" />
        <di:waypoint x="430" y="150" />
        <di:waypoint x="430" y="360" />
        <di:waypoint x="460" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="360" />
        <di:waypoint x="615" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Yes_di" bpmnElement="Flow_Yes">
        <di:waypoint x="665" y="360" />
        <di:waypoint x="720" y="360" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="684" y="342" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_No_di" bpmnElement="Flow_No">
        <di:waypoint x="640" y="385" />
        <di:waypoint x="640" y="442" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="648" y="411" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SubComplete_di" bpmnElement="Flow_SubComplete">
        <di:waypoint x="1240" y="360" />
        <di:waypoint x="1400" y="360" />
        <di:waypoint x="1400" y="150" />
        <di:waypoint x="1552" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Compensate_di" bpmnElement="Flow_Compensate">
        <di:waypoint x="1000" y="458" />
        <di:waypoint x="1000" y="520" />
        <di:waypoint x="1060" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToFailed_di" bpmnElement="Flow_ToFailed">
        <di:waypoint x="1160" y="520" />
        <di:waypoint x="1212" y="520" />
      </bpmndi:BPMNEdge>
      <!-- Return Flow Edges -->
      <bpmndi:BPMNEdge id="Flow_Ret1_di" bpmnElement="Flow_Ret1">
        <di:waypoint x="248" y="230" />
        <di:waypoint x="300" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ret2_di" bpmnElement="Flow_Ret2">
        <di:waypoint x="400" y="230" />
        <di:waypoint x="430" y="230" />
        <di:waypoint x="430" y="620" />
        <di:waypoint x="460" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ret3_di" bpmnElement="Flow_Ret3">
        <di:waypoint x="560" y="620" />
        <di:waypoint x="620" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ret4_di" bpmnElement="Flow_Ret4">
        <di:waypoint x="720" y="620" />
        <di:waypoint x="780" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ret5_di" bpmnElement="Flow_Ret5">
        <di:waypoint x="880" y="620" />
        <di:waypoint x="940" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ret6_di" bpmnElement="Flow_Ret6">
        <di:waypoint x="1040" y="620" />
        <di:waypoint x="1500" y="620" />
        <di:waypoint x="1500" y="230" />
        <di:waypoint x="1552" y="230" />
      </bpmndi:BPMNEdge>
      <!-- Subprocess Internal Edges -->
      <bpmndi:BPMNEdge id="SubFlow_1_di" bpmnElement="SubFlow_1">
        <di:waypoint x="776" y="370" />
        <di:waypoint x="800" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SubFlow_2_di" bpmnElement="SubFlow_2">
        <di:waypoint x="900" y="370" />
